# Copy to .env and fill in before `docker compose up`.

# Shared-secret gate for /ws and /api/*. Leave unset only if the service
# stays on 127.0.0.1 / a fully trusted network.
GROK_CHAT_TOKEN=

# Host directory to mount as /workspace (grok's default project root).
GROK_CHAT_PROJECTS_DIR=.

# Host's grok CLI config/session dir (must already be logged in via `grok`).
GROK_HOME_DIR=~/.grok

# HTTP port published on the host.
PORT=8787

# Address the port is published on. Defaults to loopback-only (127.0.0.1) --
# this service can read arbitrary files under GROK_CHAT_CWD and, with
# GROK_CHAT_AUTO_APPROVE=1, run tools with no per-action approval gate.
# Only widen this once GROK_CHAT_TOKEN is set.
BIND_ADDR=127.0.0.1
