# Copy to docker-compose.override.yml (gitignored) to pin this to your own
# Docker setup instead of the portable defaults in docker-compose.yml.
services:
  grok-chat-web:
    restart: always
    logging:
      driver: json-file
      options:
        max-size: "2m"
        max-file: "1"
    dns:
      - 172.20.0.53   # your DNS server, e.g. a local AdGuard/Pi-hole
    # Optional extra quick-pick project roots, shown in the UI's root
    # switcher alongside the default GROK_CHAT_CWD. No env vars needed --
    # just mount each one under /roots/<name>; the app lists whatever
    # subdirectories are actually there, so the name can't drift from
    # the mount. Add as many -v lines as you want.
    volumes:
      - /path/on/host/workspaces:/roots/workspaces
      - /path/on/host/notes:/roots/notes
    # Static IP so restarts don't shuffle it (useful if anything on your
    # network refers to this container by IP instead of container name).
    networks:
      default:
        ipv4_address: 172.20.0.4

networks:
  default:
    name: your-existing-docker-network
    external: true
